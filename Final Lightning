//Struktur med variabler af data, den får tilsendt
typedef struct struct_message {
  int id;
  int button1Data = 0;
  int button2Data = 0;
  int button3Data = 0;
  int button4Data = 0;
  int button5Data = 0;
}struct_message;

//Gem strukturen i variablen previousState
struct_message previousState;

//Her laves der variabler, som holder data for hver sender
struct_message board1;
