//Callback funktion der bliver udført når data er modtaget
void OnDataRecv(const uint8_t * mac_addr, const uint8_t *incomingData, int len) {
  char macStr[18];
  Serial.print("Packet received from: ");
  snprintf(macStr, sizeof(macStr), "%02x:%02x:%02x:%02x:%02x:%02x",
           mac_addr[0], mac_addr[1], mac_addr[2], mac_addr[3], mac_addr[4], mac_addr[5]);
  Serial.println(macStr);
  memcpy(&previousState, incomingData, sizeof(previousState));
  Serial.printf("Board ID %u: %u bytes\n", previousState.id, len);

  
  //Opdater med det nye data
  boardsStruct[previousState.id-1].button1Data = previousState.button1Data;
  boardsStruct[previousState.id-1].button2Data = previousState.button2Data;
  boardsStruct[previousState.id-1].button3Data = previousState.button3Data;
  boardsStruct[previousState.id-1].button4Data = previousState.button4Data;
  boardsStruct[previousState.id-1].button5Data = previousState.button5Data;
  
  boardsStruct[previousState.id-1].button1Data = previousState.button1Data;
  boardsStruct[previousState.id-1].button2Data = previousState.button2Data;
  boardsStruct[previousState.id-1].button3Data = previousState.button3Data;
  boardsStruct[previousState.id-1].button4Data = previousState.button4Data;
  boardsStruct[previousState.id-1].button5Data = previousState.button5Data;

  //Print data i konsollen
  Serial.printf("Button 1: %d \n", boardsStruct[previousState.id-1].button1Data);
  Serial.printf("Button 2: %d \n", boardsStruct[previousState.id-1].button2Data);
  Serial.printf("Button 3: %d \n", boardsStruct[previousState.id-1].button3Data);
  Serial.printf("Button 4: %d \n", boardsStruct[previousState.id-1].button4Data);
  Serial.printf("Button 5: %d \n", boardsStruct[previousState.id-1].button5Data);

  Serial.printf("Button 6: %d \n", boardsStruct[previousState.id-1].button1Data);
  Serial.printf("Button 7: %d \n", boardsStruct[previousState.id-1].button2Data);
  Serial.printf("Button 8: %d \n", boardsStruct[previousState.id-1].button3Data);
  Serial.printf("Button 9: %d \n", boardsStruct[previousState.id-1].button4Data);
  Serial.printf("Button 10: %d \n", boardsStruct[previousState.id-1].button5Data);

  Serial.println();
}
 
void setup() {
  //Initialiser Serial Monitor
  Serial.begin(115200);

  //Initialiser Neopixel
  pixels.begin();
  pixels2.begin();

  //Sæt enheden som en Wi-Fi Station
  WiFi.mode(WIFI_STA);

  //Initialiser ESP-NOW
  if (esp_now_init() != ESP_OK) {
    Serial.println("Error initializing ESP-NOW");
    return;
  }
  
  //Registrer en callback funktion, når data er modtaget
  esp_now_register_recv_cb(esp_now_recv_cb_t(OnDataRecv));

  //Forsøg på at holde lyset slukket ved start
  start();
}

