//Starter med alle lys slukket ved at løbe gennem begge array for lysene og sætter dem til color1 (slukket)
void start() {
   for(int i=0; i<=17; i++) { // For each pixel...
    pixels.setPixelColor(i, color1); 
   }
   for(int i=0; i<=30; i++) { // For each pixel...
    pixels2.setPixelColor(i, color1);
   }

  //Sørg for det vises
  pixels.show();
  pixels2.show();
}

